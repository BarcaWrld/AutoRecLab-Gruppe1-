ate=seed)\\n    # Create interactions matrix\\n    interactions_train = train.pivot(index=\'user\', columns=\'item\', values=\'rating\').fillna(0).to_numpy()\\n    # Fit model\\n    model.fit(interactions_train, epochs=10, num_threads=2)\\n    \\n    # Generate predictions for the test set\\n    interactions_test = test.pivot(index=\'user\', columns=\'item\', values=\'rating\').fillna(0)\\n    test_users = interactions_test.index.tolist()\\n    test_items = interactions_test.columns.tolist()\\n\\n    # Create a predicted scores matrix\\n    predicted_scores = model.predict(test_users, test_items)\\n\\n    # Calculate metrics\\n    ndcg_score = ndcg(test[\'item\'], predicted_scores[test[\'user\']], k=10)\\n    recall_score = recall(test[\'item\'], predicted_scores[test[\'user\']], k=10)\\n    experiment_data[\'movie_lens_100K\'][\'metrics\'][\'ndcg\'].append(ndcg_score)\\n    experiment_data[\'movie_lens_100K\'][\'metrics\'][\'recall\'].append(recall_score)\\n\\n# Save experiment data\\nnp.save(os.path.join(working_dir, \'experiment_data.npy\'), experiment_data)\\nprint(\'Saved experiment data: \', experiment_data)"}', name='return_plan_and_code'), type='function')]))[/cyan]
